---
const { eyebrow, title, lede, ledeHtml } = Astro.props;
---
<section class="page-hero section-dark">
  <div class="wrap-narrow">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {ledeHtml ? <p class="lede" set:html={ledeHtml} /> : lede && <p class="lede">{lede}</p>}
  </div>
</section>

<style>
  .page-hero {
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.5rem, 5vw, 4rem);
    background:
      radial-gradient(120% 80% at 80% -10%, rgba(255,179,71,0.12), transparent 60%),
      var(--deep);
  }
  .page-hero h1 { margin-bottom: 0.6rem; }
</style>
