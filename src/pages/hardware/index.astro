---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";

const picks = [
  {
    name: "Seeed Wio Tracker L1 Pro",
    tag: "Easiest to start",
    price: "≈ $40",
    url: "https://www.seeedstudio.com/Wio-Tracker-L1-Pro-p-6454.html",
    blurb:
      "If you want something that works the moment you open the box, start here. It comes assembled with a little screen, a built-in battery, and even a solar input to help top it up. Turn it on, pair it with your phone, and you're on the mesh.",
    best: "Most neighbors — especially if you're not into gadgets.",
  },
  {
    name: "RAK WisMesh Tag",
    tag: "Best pocket tag",
    price: "≈ $40",
    url: "https://store.rakwireless.com/products/wismesh-tag-meshtastic-gps-lora-tracker-ip66",
    blurb:
      "A sealed, weatherproof tag about the size of a credit card, with the antennas tucked inside so there's nothing to stick out or snap off. It clips to a bag or lanyard, the battery lasts a couple of days, and it shrugs off rain. Built to just live in your pocket.",
    best: "People who want something tiny and rugged to carry everywhere.",
  },
  {
    name: "Elecrow ThinkNode M1",
    tag: "Best screen",
    price: "≈ $54",
    url: "https://store.rokland.com/products/elecrow-thinknode-m1-lora-meshtastic-radio-1-54-epd-screen-gps-nrf52840",
    blurb:
      "A proper little handheld with buttons and an e-paper screen you can read in bright sunlight — so you can see messages right on the device without reaching for your phone. The battery stretches to four or five days. This link ships from within the US.",
    best: "Anyone who wants to read messages on the device itself.",
  },
  {
    name: "Heltec MeshPocket",
    tag: "Two-in-one",
    price: "≈ $49",
    url: "https://heltec.org/project/meshpocket/",
    blurb:
      "Clever idea: it's a phone power bank that's also a mesh radio. You'd carry a battery pack anyway, so this one keeps your phone charged and keeps you on PalmasMesh at the same time. It even charges your phone wirelessly. (Not weatherproof, so keep it dry.)",
    best: "Folks who'd rather not carry a separate gadget.",
  },
];

const mentions = [
  {
    name: "muzi.works SuperBase Kit",
    url: "https://muzi.works/products/superbase-kit",
  },
  {
    name: "Seeed SenseCAP T1000-E",
    url: "https://www.seeedstudio.com/SenseCAP-Card-Tracker-T1000-E-for-Meshtastic-p-5913.html",
  },
];
---
<Base
  title="What to buy"
  description="The radios that get you onto PalmasMesh, explained in plain language. Four portable picks for every budget — and the one rule you can't skip."
>
  <PageHero
    eyebrow="Getting started · Step 1"
    title="What to buy to get on the mesh"
    lede="You need one small radio you can carry with you. That's the whole shopping list. Here are the four we'd point a neighbor to, from the simplest to the most hands-on."
  />

  <!-- The one rule -->
  <section class="section">
    <div class="wrap-narrow">
      <div class="rule-box">
        <span class="rule-icon" aria-hidden="true">⚠</span>
        <div>
          <h3>One rule you can't skip</h3>
          <p>
            <strong>It has to be a Meshtastic device set to the 915&nbsp;MHz US
            band</strong> (sometimes written 902–928&nbsp;MHz). That's what
            Puerto Rico uses — a device set for Europe (868&nbsp;MHz) won't talk
            to the rest of us. When ordering, look for "US" or "915&nbsp;MHz."
            Not sure? Ask us before you buy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Picks -->
  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <p class="eyebrow">Our picks</p>
      <h2>Four good ways to get started</h2>
      <p class="lede" style="max-width:54ch;">
        Any of these will get you onto PalmasMesh. There's no wrong choice — it
        mostly comes down to your budget and what you'd like it to do.
      </p>
      <div class="grid grid-2 picks">
        {picks.map((p) => (
          <article class="card pick">
            <div class="pick-head">
              <span class="pill">{p.tag}</span>
              <span class="pick-price">{p.price}</span>
            </div>
            <h3>{p.name}</h3>
            <p>{p.blurb}</p>
            <p class="pick-best"><strong>Best for:</strong> {p.best}</p>
            <a class="pick-link" href={p.url} target="_blank" rel="noopener">View this device →</a>
          </article>
        ))}
      </div>

      <div class="mentions">
        <h4>Also worth a look</h4>
        <p>
          A couple of other solid, ready-to-use options if none of the above fit:{" "}
          {mentions.map((m, i) => (
            <>
              <a href={m.url} target="_blank" rel="noopener">{m.name}</a>{i < mentions.length - 1 ? ", " : "."}
            </>
          ))}
        </p>
      </div>

      <p class="disclosure">A note on links: some links on this page may be affiliate links, meaning PalmasMesh could earn a small commission if you buy through them — at no extra cost to you. We only recommend gear we'd tell a neighbor to buy, commission or not.</p>
    </div>
  </section>

  <!-- Antenna note -->
  <section class="section section-tide">
    <div class="wrap-narrow">
      <p class="eyebrow">A common question</p>
      <h2>Do I need a bigger antenna?</h2>
      <p>
        Usually not. As we build out PalmasMesh, the goal is solid coverage
        across the whole community — so a sealed "tag" with an antenna tucked
        inside, or a device with the small "stubby" antenna it ships with,
        should work fine for everyday carry.
      </p>
      <p>
        A larger antenna mostly helps in two cases: a fixed node mounted up high,
        or if you're out near the edge of our coverage. Start with whatever's in
        the box — you can always add a better antenna later if you find you need
        one.
      </p>
    </div>
  </section>

  <!-- Host a node -->
  <section class="section">
    <div class="wrap-narrow">
      <p class="eyebrow">Want to do more?</p>
      <h2>Thinking about hosting a permanent node?</h2>
      <p>
        The four picks above are all <strong>portable client devices</strong> —
        the kind you carry with you. They're not meant to be permanent
        infrastructure.
      </p>
      <p>
        If you'd like to contribute to the network in a bigger way — installing
        a permanent outdoor node on a roof or high point to extend coverage for
        the whole community — that's a different (and hugely valuable) kind of
        setup. We'd love to help you get it right. Get in touch and we'll guide
        you toward the right hardware and the best spot to put it.
      </p>
      <div class="next-row">
        <a href="/setup/" class="btn btn-primary">Next: set up your device →</a>
        <a href="/faq/" class="btn btn-dark">Still have questions?</a>
      </div>
    </div>
  </section>

  <style>
    .rule-box {
      display: flex;
      gap: 1.1rem;
      align-items: flex-start;
      background: rgba(255,179,71,0.1);
      border: 1px solid rgba(255,154,46,0.35);
      border-left: 4px solid var(--signal);
      border-radius: var(--radius);
      padding: 1.4rem 1.5rem;
    }
    .rule-icon { font-size: 1.6rem; line-height: 1.2; }
    .rule-box h3 { margin-bottom: 0.4rem; }
    .rule-box p { margin-bottom: 0; }

    .picks { margin-top: 2rem; }
    .pick { display: flex; flex-direction: column; }
    .pick-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.6rem;
      margin-bottom: 0.9rem;
    }
    .pick-price {
      font-family: var(--mono);
      font-size: 0.9rem;
      color: var(--ink-soft);
      white-space: nowrap;
    }
    .pick h3 { margin-bottom: 0.5rem; }
    .pick-best {
      margin-top: auto;
      padding-top: 0.9rem;
      font-size: 0.92rem;
      color: var(--ink-soft);
    }
    .pick-link {
      padding-top: 0.7rem;
      font-weight: 600;
    }

    .disclosure {
      margin: 2.2rem auto 0;
      font-size: 0.86rem;
      color: var(--ink-soft);
      max-width: 80ch;
      font-style: italic;
      text-align: center;
    }

    .mentions { margin-top: 1.6rem; }
    .mentions h4 { color: var(--signal); margin-bottom: 0.4rem; }
    .mentions p { color: var(--ink-soft); }

    .next-row { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 1.5rem; }
  </style>
</Base>
