---
import Base from "../layouts/Base.astro";
---
<Base title="Page not found" description="That page isn't here.">
  <section class="section section-dark" style="min-height:50vh;display:grid;place-items:center;text-align:center;">
    <div class="wrap-narrow">
      <p class="eyebrow">Signal lost</p>
      <h1>We can't find that page.</h1>
      <p class="lede">The link may be old, or the page may have moved. Let's get you back on the mesh.</p>
      <div style="display:flex;gap:0.8rem;flex-wrap:wrap;justify-content:center;margin-top:1.5rem;">
        <a href="/" class="btn btn-primary">Back home →</a>
        <a href="/faq/" class="btn btn-ghost">Read the FAQ</a>
      </div>
    </div>
  </section>
</Base>
